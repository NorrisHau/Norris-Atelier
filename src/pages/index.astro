---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="page-enter app-layout content-grid">
    <section class="theme-hero content-grid__full border-b border-border py-10">
      <p class="theme-eyebrow">Nana's Wealth Log · 2026</p>
      <h1 class="theme-title">用极简框架，构建长期有效的投资系统</h1>
      <p class="theme-subtitle">
        以都市生活叙事为线索，把资产配置、风险管理与市场常识，拆解成可执行的日常动作。
      </p>

      <div class="theme-switcher" role="tablist" aria-label="内容主题">
        <button
          type="button"
          class="theme-chip is-active"
          data-theme="investment"
          role="tab"
          aria-selected="true"
          aria-controls="theme-panel-investment"
          id="theme-tab-investment"
        >
          <span class="theme-chip__icon" aria-hidden="true">💰</span>
          投资
        </button>
        <button
          type="button"
          class="theme-chip"
          data-theme="technology"
          role="tab"
          aria-selected="false"
          aria-controls="theme-panel-technology"
          id="theme-tab-technology"
        >
          <span class="theme-chip__icon" aria-hidden="true">💻</span>
          科技
        </button>
        <button
          type="button"
          class="theme-chip"
          data-theme="health"
          role="tab"
          aria-selected="false"
          aria-controls="theme-panel-health"
          id="theme-tab-health"
        >
          <span class="theme-chip__icon" aria-hidden="true">✚</span>
          健康
        </button>
      </div>
    </section>

    <section
      id="theme-panel-investment"
      class="theme-panel py-10"
      role="tabpanel"
      aria-labelledby="theme-tab-investment"
    >
      <div class="mb-8 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-wide">投资主题</h2>
        <span class="text-sm text-foreground/60"
          >当前已上线章节：{sortedPosts.length}</span
        >
      </div>
      <ul class="theme-grid">
        {
          sortedPosts.map((data, index) => (
            <Card variant="h3" index={index} lazy={index > 5} {...data} />
          ))
        }
      </ul>
      <div id="home-posts-sentinel" class="h-4" aria-hidden="true"></div>
    </section>

    <section
      id="theme-panel-technology"
      class="theme-panel hidden py-10"
      role="tabpanel"
      aria-labelledby="theme-tab-technology"
    >
      <div class="rounded-2xl border border-border bg-background p-6">
        <h2 class="text-2xl font-semibold tracking-wide">科技主题</h2>
        <p class="mt-3 text-foreground/70">先放 3 篇占位预告，后续逐步替换成正式内容。</p>
        <ul class="mt-4 grid gap-3 text-sm text-foreground/80">
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">AI 工具流：从输入到可复用产出</h3>
            <p class="mt-1 text-foreground/65">
              记录个人内容工作流：选题、素材池、提示词模板、复盘看板。
            </p>
          </li>
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">信息系统：如何构建低摩擦知识库</h3>
            <p class="mt-1 text-foreground/65">
              用标签、双链与检索习惯，让“收藏”真正变成“可调用”。
            </p>
          </li>
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">技术职业成长：从执行者到系统设计者</h3>
            <p class="mt-1 text-foreground/65">
              聚焦反馈循环、复利能力和跨学科协作的成长路径。
            </p>
          </li>
        </ul>
      </div>
    </section>
    <section
      id="theme-panel-health"
      class="theme-panel hidden py-10"
      role="tabpanel"
      aria-labelledby="theme-tab-health"
    >
      <div class="rounded-2xl border border-border bg-background/80 p-6">
        <h2 class="text-2xl font-semibold tracking-wide">健康主题</h2>
        <p class="mt-3 text-foreground/70">先放 3 篇占位预告，后续会上线完整章节。</p>
        <ul class="mt-4 grid gap-3 text-sm text-foreground/80">
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">高压工作下的恢复系统</h3>
            <p class="mt-1 text-foreground/65">
              从睡眠、呼吸、微休息开始，建立可重复执行的恢复协议。
            </p>
          </li>
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">运动最小行动集：忙碌也能持续</h3>
            <p class="mt-1 text-foreground/65">
              提供 15 分钟可完成的力量+心肺组合，主打低门槛和一致性。
            </p>
          </li>
          <li class="rounded-xl border border-border bg-card-bg/80 p-4">
            <h3 class="text-base font-semibold">饮食与注意力：稳定能量曲线</h3>
            <p class="mt-1 text-foreground/65">
              通过简单可执行的餐盘策略，减少午后疲惫和认知波动。
            </p>
          </li>
        </ul>
      </div>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        文章目录
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    const tabs = Array.from(document.querySelectorAll(".theme-chip"));
    const panels = Array.from(document.querySelectorAll(".theme-panel"));

    const activate = (theme: string | undefined) => {
      if (!theme) return;
      tabs.forEach(tab => {
        const tabEl = tab as HTMLElement;
        const isSelected = tabEl.dataset.theme === theme;
        tabEl.classList.toggle("is-active", isSelected);
        tabEl.setAttribute("aria-selected", isSelected ? "true" : "false");
      });

      panels.forEach(panel => {
        const shouldShow = panel.id === `theme-panel-${theme}`;
        panel.classList.toggle("hidden", !shouldShow);
      });
    };

    tabs.forEach(tab => {
      const tabEl = tab as HTMLElement;
      tabEl.addEventListener("click", () => activate(tabEl.dataset.theme));
    });

    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-home-card]")
    );
    const sentinel = document.querySelector<HTMLElement>("#home-posts-sentinel");
    if (!cards.length || !sentinel) return;

    const estimateCardHeight = 168;
    const initialCount = Math.max(
      6,
      Math.ceil(((window.innerHeight || 800) * 2) / estimateCardHeight)
    );
    const batchCount = 4;
    let shownCount = 0;

    const reveal = (count: number) => {
      const nextCount = Math.min(cards.length, shownCount + count);
      for (let i = shownCount; i < nextCount; i++) {
        cards[i]?.removeAttribute("hidden");
      }
      shownCount = nextCount;
      if (shownCount >= cards.length) observer?.disconnect();
    };

    reveal(initialCount);

    const observer = new IntersectionObserver(
      entries => {
        if (entries.some(entry => entry.isIntersecting)) {
          reveal(batchCount);
        }
      },
      { rootMargin: "220px 0px" }
    );

    observer.observe(sentinel);
  });
</script>
